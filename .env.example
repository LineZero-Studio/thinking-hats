# Public demo mode. When true, the app shows the prepared example and never calls OpenAI.
EXAMPLE_ONLY_DEMO=true

# Set this to your public repo URL so the in-app GitHub links point to your fork.
NEXT_PUBLIC_GITHUB_URL=https://github.com/LineZero-Studio/thinking-hats

# Live AI mode. To enable it, set EXAMPLE_ONLY_DEMO=false and provide both
# OPENAI_API_KEY and MVP_ACCESS_CODE in your local or Vercel environment.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# OPENAI_REASONING_EFFORT=low
# OPENAI_FALLBACK_MODEL=gpt-5-mini
# MVP_ACCESS_CODE=
